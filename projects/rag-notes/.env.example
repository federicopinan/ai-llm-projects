# Configuration template. Copy to `.env` and edit values as needed.
# All variables have safe defaults; this file is the source of truth.

# --- Notes source ----------------------------------------------------------
# Directory containing the markdown notes to index. Relative paths are
# anchored at the project root (projects/rag-notes/).
NOTES_PATH=./data/sample_notes

# --- Vector store ----------------------------------------------------------
# Local path for the embedded ChromaDB. Ignored when CHROMA_URL is set.
CHROMA_PATH=./chroma_db

# Optional: point to a ChromaDB server (e.g. one started via docker-compose).
# Leave commented out for the default embedded mode.
# CHROMA_URL=http://localhost:8000

COLLECTION_NAME=private_notes

# --- Retrieval -------------------------------------------------------------
# Number of chunks returned for each query.
TOP_K=4
# Approximate target chunk size in characters.
CHUNK_SIZE=800
# Tail of each chunk carried into the next chunk, in characters.
CHUNK_OVERLAP=120

# --- Optional local LLM ----------------------------------------------------
# When LLM_MODEL is set AND an Ollama server is reachable at OLLAMA_BASE_URL,
# query.py asks Ollama to generate a grounded answer. Leave LLM_MODEL empty
# (or unset) to disable the LLM and use the extractive fallback only.
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1