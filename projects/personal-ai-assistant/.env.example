# Copy this file to .env and adjust values for your local setup.
# Never commit a real .env file with secrets or credentials.

# Base URL of a local Ollama instance.
# Used only when ASSISTANT_MODE=ollama.
OLLAMA_BASE_URL=http://localhost:11434

# Model name to request from Ollama.
# Must be available locally: run `ollama pull <model>` first.
LLM_MODEL=llama3.1

# Operating mode:
#   prompt-only -> CLI prints the structured prompt and stops (default).
#   ollama      -> CLI also sends the prompt to the local Ollama instance.
ASSISTANT_MODE=prompt-only